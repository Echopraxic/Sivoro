    <div class="footer-bottom">
      <p class="footer-copy">© {year} Sivoro Microfluidics. All rights reserved.</p>
      <p class="footer-copy">Seed round open · $1.5M · Pre-money $6M</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0B0F19;
    border-top: 1px solid #1F2937;
    padding: 4rem 0 2rem;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #1F2937;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .footer-wordmark {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #F8F9FA;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: #8B95A5;
    line-height: 1.6;
    max-width: 280px;
    margin: 0 0 1.25rem;
  }

  .footer-socials {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: #111827;
    border: 1px solid #1F2937;
    border-radius: 8px;
    color: #8B95A5;
    transition: color 200ms, border-color 200ms;
  }
  .social-link:hover { color: #00D4AA; border-color: #00D4AA; }

  .footer-col h4.footer-col-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F8F9FA;
    margin: 0 0 1rem;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-col a {
    font-size: 0.875rem;
    color: #8B95A5;
    text-decoration: none;
    transition: color 200ms;
  }
  .footer-col a:hover { color: #F8F9FA; }

  .footer-email {
    font-size: 0.875rem;
    color: #00D4AA;
    text-decoration: none;
  }
  .footer-email:hover { text-decoration: underline; }

  .footer-bottom {
    padding-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: #8B95A5;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 600px) {
    .footer-top { grid-template-columns: 1fr; }
    .footer-brand { grid-column: auto; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
