---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sivoro Microfluidics | Living Microfluidic Chips"
  description="The first self-assembling, optogenetically controlled microfluidic platform. One fungus. One week. Zero cleanroom."
>
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SECTION 1 · HERO                                           -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section id="hero" style="position:relative; min-height:100vh; display:flex; align-items:center; overflow:hidden; padding-top:64px;">
    <canvas id="hyphal-canvas" style="position:absolute; inset:0; width:100%; height:100%; opacity:0.45; pointer-events:none;"></canvas>

    <div style="position:absolute; inset:0; background:radial-gradient(ellipse 80% 60% at 60% 40%, rgba(0,212,170,0.06) 0%, transparent 70%); pointer-events:none;"></div>
    <div style="position:absolute; bottom:0; left:0; right:0; height:200px; background:linear-gradient(transparent, #0B0F19); pointer-events:none;"></div>

    <div class="container" style="position:relative; z-index:1; padding-top:4rem; padding-bottom:4rem;">
      <div style="max-width:720px;">
        <span class="section-label hero-fade" style="--delay:0ms">Sivoro Microfluidics · Seed Round 2026</span>

        <h1 class="hero-fade" style="--delay:80ms; font-size:clamp(2.5rem,5.5vw,4.5rem); font-weight:700; line-height:1.05; margin:0 0 1.25rem; font-family:var(--font-display);">
          Living channels.<br>
          <span style="color:#00D4AA;">Programmable flow.</span>
        </h1>

        <p class="hero-fade" style="--delay:160ms; font-size:clamp(1rem,1.8vw,1.25rem); color:#8B95A5; line-height:1.65; margin:0 0 2.5rem; max-width:560px;">
          The first self-assembling, optogenetically controlled microfluidic platform. No cleanroom required.
        </p>

        <div class="hero-fade" style="--delay:240ms; display:flex; flex-wrap:wrap; gap:1rem; margin-bottom:3rem;">
          <a href="/technology" class="btn-primary">See the Technology →</a>
          <a href="/investors" class="btn-secondary">Investor Briefing</a>
        </div>

        <div class="hero-fade" style="--delay:360ms; display:flex; flex-wrap:wrap; gap:0.625rem;">
          <span class="stat-badge">10,440 KO pairs screened</span>
          <span class="stat-badge">100× dynamic range</span>
          <span class="stat-badge">&lt;$1 per device</span>
          <span class="stat-badge">18 months to prototype</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SECTION 2 · THE PROBLEM                                    -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="bg-dark">
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:start;">
        <div class="reveal">
          <span class="section-label">The Problem</span>
          <h2 class="headline">Microfluidics is stuck in the cleanroom.</h2>
          <p class="subhead" style="margin-bottom:2.5rem;">Every experiment starts with a photomask and weeks of fabrication. Biology moved on — microfluidics hasn't.</p>

          <div style="display:flex; flex-direction:column; gap:1rem;">
            <div class="card">
              <div style="display:flex; gap:1rem; align-items:flex-start;">
                <span style="font-size:1.5rem; font-weight:700; color:#00D4AA; font-variant-numeric:tabular-nums; min-width:2rem; line-height:1.2;">01</span>
                <div>
                  <h3 style="margin:0 0 0.5rem; font-size:1rem; font-weight:600; color:#F8F9FA;">2–4 weeks per chip, $5k–$20k per mask</h3>
                  <p style="margin:0; font-size:0.875rem; color:#8B95A5; line-height:1.6;">PDMS fabrication requires a cleanroom. Each design change means a new photomask — slow iteration, high cost, high barrier to entry.</p>
                </div>
              </div>
            </div>
            <div class="card">
              <div style="display:flex; gap:1rem; align-items:flex-start;">
                <span style="font-size:1.5rem; font-weight:700; color:#00D4AA; min-width:2rem; line-height:1.2;">02</span>
                <div>
                  <h3 style="margin:0 0 0.5rem; font-size:1rem; font-weight:600; color:#F8F9FA;">Passive channels — no programmability</h3>
                  <p style="margin:0; font-size:0.875rem; color:#8B95A5; line-height:1.6;">Active valves require complex external pneumatic systems. No built-in actuation. No design reusability across projects.</p>
                </div>
              </div>
            </div>
            <div class="card">
              <div style="display:flex; gap:1rem; align-items:flex-start;">
                <span style="font-size:1.5rem; font-weight:700; color:#00D4AA; min-width:2rem; line-height:1.2;">03</span>
                <div>
                  <h3 style="margin:0 0 0.5rem; font-size:1rem; font-weight:600; color:#F8F9FA;">Single-use waste — clogging kills the chip</h3>
                  <p style="margin:0; font-size:0.875rem; color:#8B95A5; line-height:1.6;">Channel fouling is terminal. Each clog means discarding the device and restarting fabrication from scratch.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="reveal">
          <div class="card-amber" style="margin-bottom:1.5rem;">
            <p class="section-label-amber">Market Opportunity</p>
            <p style="font-size:clamp(2.5rem,5vw,4rem); font-weight:700; color:#F5A623; margin:0 0 0.5rem; font-family:var(--font-display);">$25B</p>
            <p style="color:#8B95A5; font-size:0.9375rem; line-height:1.5; margin:0;">Microfluidics market by 2028 — growth limited by fabrication bottlenecks and passive chip designs.</p>
          </div>
          <div class="card">
            <p class="section-label">The Core Bottleneck</p>
            <p style="color:#F8F9FA; font-size:1.0625rem; line-height:1.6; margin:0;">Every experiment starts with a cleanroom. Biology moved on — microfluidics hasn't.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SECTION 3 · THE SOLUTION                                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="bg-light">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:3rem;">
        <span class="section-label">The Solution</span>
        <h2 class="headline">One fungus. One week. <span style="color:#00D4AA;">Zero cleanroom.</span></h2>
        <p class="subhead" style="max-width:560px; margin:0 auto;">Sivoro replaces photolithography with engineered fungi that self-assemble into precision microfluidic channels.</p>
      </div>

      <div class="reveal" style="overflow-x:auto; -webkit-overflow-scrolling:touch; border-radius:12px; border:1px solid #E5E7EB; background:#fff; box-shadow:0 4px 24px rgba(0,0,0,0.08);">
        <table class="data-table" style="min-width:600px;">
          <thead>
            <tr>
              <th style="background:#F9FAFB; color:#374151;">Feature</th>
              <th style="color:#059669; background:rgba(0,212,170,0.08);">Sivoro Living Chip</th>
              <th style="background:#F9FAFB; color:#374151;">Conventional PDMS</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td style="color:#374151; font-weight:500;">Fabrication</td>
              <td style="background:rgba(0,212,170,0.04); color:#059669; font-weight:500;">Fungus grows channels</td>
              <td style="color:#6B7280;">Photolithography (cleanroom)</td>
            </tr>
            <tr>
              <td style="color:#374151; font-weight:500;">Valves</td>
              <td style="background:rgba(0,212,170,0.04); color:#059669; font-weight:500;">Light-controlled (450 nm, built-in)</td>
              <td style="color:#6B7280;">Pneumatic pumps (external)</td>
            </tr>
            <tr>
              <td style="color:#374151; font-weight:500;">Iteration</td>
              <td style="background:rgba(0,212,170,0.04); color:#059669; font-weight:500;">Days (transform strain)</td>
              <td style="color:#6B7280;">Weeks (redesign mask)</td>
            </tr>
            <tr>
              <td style="color:#374151; font-weight:500;">Channel fouling</td>
              <td style="background:rgba(0,212,170,0.04); color:#059669; font-weight:500;">Self-clearing (hyphal turnover)</td>
              <td style="color:#6B7280;">Terminal (chip disposal)</td>
            </tr>
            <tr>
              <td style="color:#374151; font-weight:500;">Per-device cost</td>
              <td style="background:rgba(0,212,170,0.04); color:#059669; font-weight:700;">&lt;$1 (after strain)</td>
              <td style="color:#6B7280;">$50–$500</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div style="text-align:center; margin-top:2rem;" class="reveal">
        <a href="/technology" class="btn-primary" style="background:#0B0F19; color:#F8F9FA;">Explore the Full Technology →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SECTION 4 · THREE LAYERS OF IP                             -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="bg-dark">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:3rem;">
        <span class="section-label">Technology</span>
        <h2 class="headline">Three layers of proprietary IP</h2>
        <p class="subhead" style="max-width:520px; margin:0 auto;">From metabolic chassis to optogenetic valve to physical scaffold — each layer independently defensible.</p>
      </div>

      <div class="grid-3 reveal-stagger">
        <div class="card" style="border-top:2px solid #00D4AA;">
          <p style="font-size:0.75rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#00D4AA; margin:0 0 1rem;">Layer 1 — Chassis</p>
          <h3 style="margin:0 0 0.75rem; font-size:1.125rem; font-weight:600; color:#F8F9FA;">Metabolically Orthogonal <em>N. crassa</em></h3>
          <p style="font-size:0.875rem; color:#8B95A5; line-height:1.65; margin:0 0 1.25rem;">Engineered to eat xylose only — cannot metabolize glucose, amino acids, or organic acids present in lab reagents. Six-gene knockout validated <em>in silico</em> from 10,440 combinations screened.</p>
          <div style="display:flex; flex-wrap:wrap; gap:0.5rem;">
            <span class="badge badge-cyan">Composition of matter</span>
            <span class="badge badge-cyan">Screening method</span>
          </div>
        </div>

        <div class="card" style="border-top:2px solid #00D4AA;">
          <p style="font-size:0.75rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#00D4AA; margin:0 0 1rem;">Layer 2 — Valve</p>
          <h3 style="margin:0 0 0.75rem; font-size:1.125rem; font-weight:600; color:#F8F9FA;">Optogenetic Septal Pore Valve</h3>
          <p style="font-size:0.875rem; color:#8B95A5; line-height:1.65; margin:0 0 1.25rem;">Blue light (450 nm) triggers pore closure. <strong style="color:#F8F9FA;">100× dynamic range</strong> between dark and lit states. LOV2-Jα-HEX1 fusion protein + SPA1-ePDZ pore-rim anchor.</p>
          <div style="display:flex; flex-wrap:wrap; gap:0.5rem;">
            <span class="badge badge-cyan">Optogenetic construct</span>
            <span class="badge badge-cyan">Flow control method</span>
          </div>
        </div>

        <div class="card" style="border-top:2px solid #F5A623;">
          <p style="font-size:0.75rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#F5A623; margin:0 0 1rem;">Layer 3 — Scaffold</p>
          <h3 style="margin:0 0 0.75rem; font-size:1.125rem; font-weight:600; color:#F8F9FA;">H-Tree Scaffold &amp; Integration</h3>
          <p style="font-size:0.875rem; color:#8B95A5; line-height:1.65; margin:0 0 1.25rem;">Parametric design (10×10 mm, 16 ports). Compatible with SU-8/PDMS or direct printing. Channel dimensions engineered for 2–8 hyphae (13–20 µm width, 15 µm depth).</p>
          <div style="display:flex; flex-wrap:wrap; gap:0.5rem;">
            <span class="badge badge-amber">Fungal-specific geometry</span>
            <span class="badge badge-amber">Co-culture methods</span>
          </div>
        </div>
      </div>

      <div style="text-align:center; margin-top:2.5rem;" class="reveal">
        <a href="/technology" class="btn-secondary">Deep-dive into the IP →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SECTION 5 · VALIDATION STATUS                              -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="bg-surface">
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center;">
        <div class="reveal">
          <span class="section-label">Development Status</span>
          <h2 class="headline">65% complete —<br>all computational phases done</h2>
          <p class="subhead" style="margin-bottom:2rem; font-style:italic;">"We are one wet-lab milestone away from a functional prototype."</p>
          <a href="/science" class="btn-secondary">View Full Milestone Plan →</a>
        </div>

        <div id="progress-bars" class="reveal">
          <div class="progress-item" data-pct="100">
            <div style="display:flex; justify-content:space-between; margin-bottom:0.375rem;">
              <span style="font-size:0.875rem; color:#F8F9FA; font-weight:500;">Metabolic Modeling</span>
              <span style="font-size:0.8125rem; color:#00D4AA; font-weight:600;">100%</span>
            </div>
            <div class="progress-track"><div class="progress-fill"></div></div>
          </div>
          <div class="progress-item" data-pct="100" style="margin-top:1.25rem;">
            <div style="display:flex; justify-content:space-between; margin-bottom:0.375rem;">
              <span style="font-size:0.875rem; color:#F8F9FA; font-weight:500;">KO Screen (10,440 pairs)</span>
              <span style="font-size:0.8125rem; color:#00D4AA; font-weight:600;">100%</span>
            </div>
            <div class="progress-track"><div class="progress-fill"></div></div>
          </div>
          <div class="progress-item" data-pct="100" style="margin-top:1.25rem;">
            <div style="display:flex; justify-content:space-between; margin-bottom:0.375rem;">
              <span style="font-size:0.875rem; color:#F8F9FA; font-weight:500;">Optogenetic Valve Design</span>
              <span style="font-size:0.8125rem; color:#00D4AA; font-weight:600;">100%</span>
            </div>
            <div class="progress-track"><div class="progress-fill"></div></div>
          </div>
          <div class="progress-item" data-pct="100" style="margin-top:1.25rem;">
            <div style="display:flex; justify-content:space-between; margin-bottom:0.375rem;">
              <span style="font-size:0.875rem; color:#F8F9FA; font-weight:500;">Chip Scaffold Design</span>
              <span style="font-size:0.8125rem; color:#00D4AA; font-weight:600;">100%</span>
            </div>
            <div class="progress-track"><div class="progress-fill"></div></div>
          </div>
          <div class="progress-item" data-pct="0" style="margin-top:1.25rem;">
            <div style="display:flex; justify-content:space-between; margin-bottom:0.375rem;">
              <span style="font-size:0.875rem; color:#8B95A5; font-weight:500;">Wet-Lab Validation</span>
              <span style="font-size:0.8125rem; color:#F5A623; font-weight:600;">Next →</span>
            </div>
            <div class="progress-track">
              <div class="progress-fill" style="background:rgba(245,166,35,0.3);"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SECTION 6 · COMPETITIVE LANDSCAPE                          -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="bg-dark">
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center;">
        <div class="reveal">
          <span class="section-label">Competitive Landscape</span>
          <h2 class="headline">The only <span style="color:#00D4AA;">living</span>, self-assembling microfluidic platform</h2>
          <p class="subhead" style="margin-bottom:2rem;">Sivoro occupies a unique position: simple fabrication, active biological control. No competitor is in this quadrant.</p>
          <table class="data-table">
            <thead>
              <tr>
                <th>Competitor</th>
                <th style="color:#00D4AA;">Sivoro Advantage</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>Emulate, Inc.</td><td class="highlight">No living channels; $200k+ instruments</td></tr>
              <tr><td>CN Bio Innovations</td><td class="highlight">Lower cost, faster iteration</td></tr>
              <tr><td>Micronit</td><td class="highlight">No cleanroom required</td></tr>
              <tr><td>Fluidigm / Standard BioTools</td><td class="highlight">10× lower price; biological actuation</td></tr>
            </tbody>
          </table>
        </div>

        <div class="reveal">
          <div style="background:#111827; border-radius:12px; border:1px solid #1F2937; overflow:hidden; aspect-ratio:1.4; position:relative;">
            <canvas id="quad-canvas" style="position:absolute; inset:0; width:100%; height:100%;"></canvas>
          </div>
          <p style="font-size:0.75rem; color:#8B95A5; text-align:center; margin-top:0.75rem;">X axis: Active control · Y axis: Fabrication simplicity</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SECTION 7 · TRACTION NUMBERS                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="bg-light">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:3rem;">
        <span class="section-label">Traction to Date</span>
        <h2 class="headline" style="color:#0B0F19;">Computational validation complete</h2>
      </div>

      <div id="counters" class="grid-3" style="margin-bottom:2.5rem;">
        <div class="reveal" style="text-align:center; padding:1.5rem;">
          <p class="counter-num" data-target="10440" style="font-size:clamp(2.5rem,5vw,3.75rem); font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display); line-height:1;">0</p>
          <p style="font-size:0.875rem; color:#374151; margin:0.5rem 0 0;">Knockout pairs screened <em>in silico</em></p>
        </div>
        <div class="reveal" style="text-align:center; padding:1.5rem;">
          <p class="counter-num" data-target="2" style="font-size:clamp(2.5rem,5vw,3.75rem); font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display); line-height:1;">0</p>
          <p style="font-size:0.875rem; color:#374151; margin:0.5rem 0 0;">Validated optogenetic constructs</p>
        </div>
        <div class="reveal" style="text-align:center; padding:1.5rem;">
          <p class="counter-num" data-target="91" style="font-size:clamp(2.5rem,5vw,3.75rem); font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display); line-height:1;">0</p>
          <p style="font-size:0.875rem; color:#374151; margin:0.5rem 0 0;">pLDDT — LOV2 domain (ColabFold)</p>
        </div>
        <div class="reveal" style="text-align:center; padding:1.5rem;">
          <p class="counter-num" data-target="88" style="font-size:clamp(2.5rem,5vw,3.75rem); font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display); line-height:1;">0</p>
          <p style="font-size:0.875rem; color:#374151; margin:0.5rem 0 0;">pLDDT — HEX1 domain (ColabFold)</p>
        </div>
        <div class="reveal" style="text-align:center; padding:1.5rem;">
          <p class="counter-num" data-target="5" style="font-size:clamp(2.5rem,5vw,3.75rem); font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display); line-height:1;">0</p>
          <p style="font-size:0.875rem; color:#374151; margin:0.5rem 0 0;">Patent families ready to file</p>
        </div>
        <div class="reveal" style="text-align:center; padding:1.5rem;">
          <p style="font-size:clamp(2.5rem,5vw,3.75rem); font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display); line-height:1;"><span class="counter-num" data-target="7600">0</span>+</p>
          <p style="font-size:0.875rem; color:#374151; margin:0.5rem 0 0;">Lines of Python modeling code</p>
        </div>
      </div>

      <div class="reveal" style="text-align:center; padding:1.5rem 2rem; background:rgba(0,212,170,0.07); border:1px solid rgba(0,212,170,0.2); border-radius:12px; max-width:580px; margin:0 auto;">
        <p style="font-size:0.75rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#00B894; margin:0 0 0.5rem;">IP Status</p>
        <p style="color:#0B0F19; font-size:0.9375rem; margin:0;">Provisional draft complete · 5 claim families · <strong>ready to file within 30 days</strong> of legal engagement</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SECTION 8 · INVESTOR CTA                                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="bg-dark">
    <div class="container">
      <div id="investor-cta" class="reveal" style="max-width:760px; margin:0 auto; border:1px solid rgba(0,212,170,0.3); border-radius:16px; padding:clamp(2rem,4vw,3.5rem); text-align:center;">
        <span class="section-label" style="display:block; margin-bottom:1rem;">Seed Round · April 2026</span>
        <h2 class="headline" style="font-size:clamp(2.5rem,5vw,4rem);">$1.5M</h2>
        <p style="color:#8B95A5; margin:0 0 2rem; font-size:1.0625rem;">18 months runway to prototype + first sale</p>

        <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; margin-bottom:2.5rem;">
          <div>
            <p style="font-size:1.375rem; font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display);">Seed</p>
            <p style="font-size:0.7rem; color:#8B95A5; margin:0.25rem 0 0; text-transform:uppercase; letter-spacing:0.08em;">Round</p>
          </div>
          <div>
            <p style="font-size:1.375rem; font-weight:700; color:#F8F9FA; margin:0; font-family:var(--font-display);">$6M</p>
            <p style="font-size:0.7rem; color:#8B95A5; margin:0.25rem 0 0; text-transform:uppercase; letter-spacing:0.08em;">Pre-money</p>
          </div>
          <div>
            <p style="font-size:1.375rem; font-weight:700; color:#F8F9FA; margin:0; font-family:var(--font-display);">$7.5M</p>
            <p style="font-size:0.7rem; color:#8B95A5; margin:0.25rem 0 0; text-transform:uppercase; letter-spacing:0.08em;">Post-money</p>
          </div>
          <div>
            <p style="font-size:1.375rem; font-weight:700; color:#F5A623; margin:0; font-family:var(--font-display);">18 mo</p>
            <p style="font-size:0.7rem; color:#8B95A5; margin:0.25rem 0 0; text-transform:uppercase; letter-spacing:0.08em;">Runway</p>
          </div>
        </div>

        <blockquote style="font-style:italic; color:#8B95A5; border-left:3px solid #00D4AA; padding-left:1.25rem; text-align:left; margin:0 0 2.5rem; font-size:1rem; line-height:1.7;">
          "We are one wet-lab milestone away from a functional prototype — exactly what this seed round funds."
        </blockquote>

        <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
          <a href="/investors" class="btn-primary">View Investor Materials →</a>
          <a href="/investors#deck" class="btn-secondary">Download Pitch Deck</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-fade {
    opacity: 0;
    transform: translateY(20px);
    animation: heroIn 700ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }
  @keyframes heroIn {
    to { opacity: 1; transform: translateY(0); }
  }

  #investor-cta {
    animation: pulse-glow 3.5s ease-in-out infinite;
  }
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0,212,170,0.12), 0 0 20px rgba(0,212,170,0.06); }
    50% { box-shadow: 0 0 0 4px rgba(0,212,170,0.1), 0 0 50px rgba(0,212,170,0.15); }
  }

  @media (max-width: 768px) {
    section .container > div[style*="grid-template-columns:1fr 1fr"] {
      display: flex !important;
      flex-direction: column !important;
    }
    #investor-cta > div[style*="grid-template-columns:repeat(4"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>

<script>
// ─── Hyphal Network Canvas ───────────────────────────────────────
(function () {
  const canvas = document.getElementById('hyphal-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;
  let W = 0, H = 0;
  let mouse = { x: -999, y: -999 };

  interface Tip {
    x: number; y: number; angle: number; speed: number;
    age: number; maxAge: number; width: number; alpha: number;
  }
  const tips: Tip[] = [];
  const MAX = 90;

  function spawnTip(x?: number, y?: number): Tip {
    return {
      x: x ?? W * (0.05 + Math.random() * 0.9),
      y: y ?? H * (0.6 + Math.random() * 0.4),
      angle: -Math.PI / 2 + (Math.random() - 0.5) * 1.4,
      speed: 0.4 + Math.random() * 0.9,
      age: 0, maxAge: 180 + Math.random() * 420,
      width: 0.7 + Math.random() * 0.9,
      alpha: 0.2 + Math.random() * 0.45,
    };
  }

  function resize() {
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
    ctx.fillStyle = '#0B0F19';
    ctx.fillRect(0, 0, W, H);
  }

  for (let i = 0; i < 14; i++) tips.push(spawnTip());

  function frame() {
    ctx.fillStyle = 'rgba(11,15,25,0.018)';
    ctx.fillRect(0, 0, W, H);

    const toAdd: Tip[] = [];
    const dead: number[] = [];

    for (let i = 0; i < tips.length; i++) {
      const t = tips[i];
      const px = t.x, py = t.y;

      const dx = t.x - mouse.x, dy = t.y - mouse.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 120 && dist > 0) {
        t.angle += (Math.atan2(dy, dx) - t.angle) * 0.04;
      }

      t.angle += (Math.random() - 0.5) * 0.16;
      t.x += Math.cos(t.angle) * t.speed;
      t.y += Math.sin(t.angle) * t.speed;
      t.age++;

      ctx.beginPath();
      ctx.moveTo(px, py);
      ctx.lineTo(t.x, t.y);
      ctx.strokeStyle = `rgba(0,212,170,${t.alpha})`;
      ctx.lineWidth = t.width;
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(t.x, t.y, t.width + 0.6, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(0,212,170,${t.alpha * 0.75})`;
      ctx.fill();

      if (Math.random() < 0.0045 && tips.length + toAdd.length < MAX) {
        toAdd.push({
          x: t.x, y: t.y,
          angle: t.angle + (Math.random() > 0.5 ? 1 : -1) * (0.3 + Math.random() * 0.5),
          speed: t.speed * 0.78, age: 0, maxAge: 100 + Math.random() * 180,
          width: t.width * 0.62, alpha: t.alpha * 0.68,
        });
      }

      if (t.age > t.maxAge || t.x < -50 || t.x > W + 50 || t.y < -50 || t.y > H + 50) {
        dead.push(i);
      }
    }

    for (let i = dead.length - 1; i >= 0; i--) tips.splice(dead[i], 1);
    tips.push(...toAdd);
    if (tips.length < 8) tips.push(spawnTip());

    requestAnimationFrame(frame);
  }

  resize();
  frame();
  window.addEventListener('resize', resize);
  window.addEventListener('mousemove', (e) => {
    const r = canvas.getBoundingClientRect();
    mouse.x = e.clientX - r.left;
    mouse.y = e.clientY - r.top;
  });
  window.addEventListener('mouseleave', () => { mouse.x = -999; mouse.y = -999; });
})();

// ─── Progress Bars ───────────────────────────────────────────────
(function () {
  const container = document.getElementById('progress-bars');
  if (!container) return;
  const obs = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      container.querySelectorAll<HTMLElement>('.progress-item').forEach((item) => {
        const fill = item.querySelector<HTMLElement>('.progress-fill')!;
        fill.style.width = (item.dataset.pct ?? '0') + '%';
      });
      obs.disconnect();
    }
  }, { threshold: 0.3 });
  obs.observe(container);
})();

// ─── Animated Counters ───────────────────────────────────────────
(function () {
  const section = document.getElementById('counters');
  if (!section) return;
  let fired = false;
  const obs = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && !fired) {
      fired = true;
      section.querySelectorAll<HTMLElement>('.counter-num').forEach((el) => {
        const target = parseInt(el.dataset.target ?? '0', 10);
        const start = performance.now();
        const dur = 1800;
        function tick(now: number) {
          const p = Math.min((now - start) / dur, 1);
          const ease = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.floor(ease * target).toLocaleString();
          if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      });
      obs.disconnect();
    }
  }, { threshold: 0.3 });
  obs.observe(section);
})();

// ─── Competitive Quadrant Map ────────────────────────────────────
(function () {
  const canvas = document.getElementById('quad-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  const DATA = [
    { name: 'Micronit', x: 0.18, y: 0.78, desc: 'Glass/PDMS fab services' },
    { name: 'Fluidigm', x: 0.72, y: 0.72, desc: 'Integrated fluidic circuits' },
    { name: 'Emulate', x: 0.50, y: 0.62, desc: 'Organ-on-chip (PDMS)' },
    { name: 'CN Bio', x: 0.30, y: 0.48, desc: 'Organ-on-chip (PDMS)' },
    { name: 'Academic\nlabs', x: 0.14, y: 0.22, desc: 'Custom fabrication' },
    { name: 'SIVORO', x: 0.86, y: 0.18, desc: 'Living · Zero cleanroom', s: true },
  ];

  let tooltip = { v: false, name: '', desc: '', x: 0, y: 0 };

  function draw() {
    const dpr = window.devicePixelRatio || 1;
    const W = canvas.offsetWidth;
    const H = canvas.offsetHeight;
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    ctx.scale(dpr, dpr);

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#111827';
    ctx.fillRect(0, 0, W, H);

    const pad = 36, mW = W - pad * 2, mH = H - pad * 2;

    // Grid lines
    ctx.strokeStyle = '#1F2937';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    ctx.beginPath();
    ctx.moveTo(pad + mW / 2, pad); ctx.lineTo(pad + mW / 2, pad + mH);
    ctx.moveTo(pad, pad + mH / 2); ctx.lineTo(pad + mW, pad + mH / 2);
    ctx.stroke();
    ctx.setLineDash([]);

    // Axis labels
    ctx.fillStyle = '#4B5563';
    ctx.font = `9px Inter, sans-serif`;
    ctx.textAlign = 'center';
    ctx.fillText('← Passive control', pad + mW * 0.22, H - 6);
    ctx.fillText('Active control →', pad + mW * 0.78, H - 6);

    // Quadrant labels (subtle)
    ctx.fillStyle = 'rgba(139,149,165,0.25)';
    ctx.font = '8px Inter, sans-serif';
    ctx.textAlign = 'left';
    ctx.fillText('COMPLEX + PASSIVE', pad + 4, pad + 12);
    ctx.textAlign = 'right';
    ctx.fillText('COMPLEX + ACTIVE', pad + mW - 4, pad + 12);
    ctx.textAlign = 'left';
    ctx.fillText('SIMPLE + PASSIVE', pad + 4, pad + mH - 6);
    ctx.textAlign = 'right';
    ctx.fillText('SIMPLE + ACTIVE', pad + mW - 4, pad + mH - 6);

    // Dots
    DATA.forEach((c) => {
      const px = pad + c.x * mW;
      const py = pad + (1 - c.y) * mH;

      if (c.s) {
        // Sivoro glow
        const g = ctx.createRadialGradient(px, py, 2, px, py, 22);
        g.addColorStop(0, 'rgba(0,212,170,0.45)');
        g.addColorStop(1, 'rgba(0,212,170,0)');
        ctx.beginPath(); ctx.arc(px, py, 22, 0, Math.PI * 2);
        ctx.fillStyle = g; ctx.fill();
        ctx.beginPath(); ctx.arc(px, py, 8, 0, Math.PI * 2);
        ctx.fillStyle = '#00D4AA'; ctx.fill();
        ctx.fillStyle = '#00D4AA';
        ctx.font = 'bold 10px "Space Grotesk", Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText('SIVORO', px, py - 14);
        ctx.font = '8px Inter, sans-serif';
        ctx.fillStyle = '#8B95A5';
        ctx.fillText('Living · Zero cleanroom', px, py + 22);
      } else {
        ctx.beginPath(); ctx.arc(px, py, 5, 0, Math.PI * 2);
        ctx.fillStyle = '#374151'; ctx.fill();
        ctx.strokeStyle = '#4B5563'; ctx.lineWidth = 1; ctx.stroke();
        ctx.fillStyle = '#8B95A5';
        ctx.font = '9px Inter, sans-serif';
        ctx.textAlign = 'center';
        const lines = c.name.split('\n');
        lines.forEach((ln, i) => ctx.fillText(ln, px, py - 10 - (lines.length - 1 - i) * 10));
      }
    });

    // Tooltip
    if (tooltip.v) {
      const tx = Math.min(tooltip.x + 8, W - 150);
      const ty = Math.max(tooltip.y - 45, 8);
      ctx.fillStyle = '#1F2937';
      ctx.strokeStyle = '#374151';
      ctx.lineWidth = 1;
      ctx.beginPath();
      if (ctx.roundRect) {
        ctx.roundRect(tx, ty, 145, 40, 6);
      } else {
        ctx.rect(tx, ty, 145, 40);
      }
      ctx.fill(); ctx.stroke();
      ctx.fillStyle = '#F8F9FA';
      ctx.font = 'bold 10px Inter, sans-serif';
      ctx.textAlign = 'left';
      ctx.fillText(tooltip.name, tx + 8, ty + 14);
      ctx.fillStyle = '#8B95A5';
      ctx.font = '9px Inter, sans-serif';
      ctx.fillText(tooltip.desc, tx + 8, ty + 28);
    }
  }

  function hitTest(mx: number, my: number) {
    const pad = 36, mW = canvas.offsetWidth - pad * 2, mH = canvas.offsetHeight - pad * 2;
    for (const c of DATA) {
      const px = pad + c.x * mW, py = pad + (1 - c.y) * mH;
      if (Math.hypot(mx - px, my - py) < 14) return c;
    }
    return null;
  }

  canvas.addEventListener('mousemove', (e) => {
    const r = canvas.getBoundingClientRect();
    const mx = e.clientX - r.left, my = e.clientY - r.top;
    const hit = hitTest(mx, my);
    tooltip = hit ? { v: true, name: hit.name.replace('\n', ' '), desc: hit.desc, x: mx, y: my } : { ...tooltip, v: false };
    canvas.style.cursor = hit ? 'pointer' : 'default';
    draw();
  });
  canvas.addEventListener('mouseleave', () => { tooltip.v = false; draw(); });

  const obs = new IntersectionObserver((e) => { if (e[0].isIntersecting) { draw(); obs.disconnect(); } }, { threshold: 0.2 });
  obs.observe(canvas);
  window.addEventListener('resize', draw);
})();
</script>
