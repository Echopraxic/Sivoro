---
import BaseLayout from '../layouts/BaseLayout.astro';

const milestones = [
  { mo: 'M2', label: 'Construct six-gene chassis', metric: 'PCR-verified knockouts', done: false },
  { mo: 'M4', label: 'SEC-MALS on CompA_v3', metric: 'R_h ≥ 28 nm', done: false },
  { mo: 'M6', label: 'BLI/SPR Jα-ePDZ binding confirmed', metric: 'K_d ≤ 1 µM lit, ≥10× dark/lit ratio', done: false },
  { mo: 'M8', label: 'Valve functional (microscopy)', metric: '≥50% pore closure at 450 nm', done: false },
  { mo: 'M10', label: 'Prototype chip colonization', metric: 'Fluorescent flow through network', done: false },
  { mo: 'M12', label: 'First customer — academic beta site', metric: 'LOI from 3 labs', done: false },
];
---

<BaseLayout
  title="Science | Sivoro Microfluidics"
  description="Computational validation complete: iJDZ836 metabolic model, 9,976 knockout pairs screened, ColabFold pLDDT 91 & 88. 12-month wet-lab milestone plan with measurable success metrics."
  keywords="iJDZ836 metabolic model, Neurospora crassa knockout screen, ColabFold structural validation, pLDDT score, BLI SPR binding, SEC-MALS protein characterization, synthetic biology validation, microfluidics research"
>
  <!-- Hero -->
  <section style="padding-top:calc(64px + 5rem); padding-bottom:4rem; background:#0B0F19; border-bottom:1px solid #1F2937;">
    <div class="container">
      <div class="reveal" style="max-width:720px;">
        <span class="section-label">Science</span>
        <h1 class="headline" style="font-size:clamp(2rem,4.5vw,3.75rem);">Computational Validation Complete</h1>
        <p class="subhead">From genome-scale metabolic models to ColabFold structural predictions — all computational phases done.</p>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section style="padding:2.5rem 0; background:#111827; border-bottom:1px solid #1F2937;">
    <div class="container">
      <div class="reveal-stagger reveal" style="display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; text-align:center;">
        <div>
          <p style="font-size:clamp(2rem,4vw,3rem); font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display);">9,976</p>
          <p style="font-size:0.8125rem; color:#8B95A5; margin:0.25rem 0 0;">KO pairs screened</p>
        </div>
        <div>
          <p style="font-size:clamp(2rem,4vw,3rem); font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display);">91</p>
          <p style="font-size:0.8125rem; color:#8B95A5; margin:0.25rem 0 0;">pLDDT — LOV2 domain</p>
        </div>
        <div>
          <p style="font-size:clamp(2rem,4vw,3rem); font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display);">88</p>
          <p style="font-size:0.8125rem; color:#8B95A5; margin:0.25rem 0 0;">pLDDT — HEX1 domain</p>
        </div>
        <div>
          <p style="font-size:clamp(2rem,4vw,3rem); font-weight:700; color:#F5A623; margin:0; font-family:var(--font-display);">65%</p>
          <p style="font-size:0.8125rem; color:#8B95A5; margin:0.25rem 0 0;">Overall completion</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tabbed data sections -->
  <section class="bg-dark" style="padding-top:3rem;">
    <div class="container">
      <div class="tab-list" role="tablist" aria-label="Science data">
        <button class="tab-btn active" role="tab" data-tab="metabolic" aria-selected="true">Metabolic Modeling</button>
        <button class="tab-btn" role="tab" data-tab="knockout" aria-selected="false">Knockout Screen</button>
        <button class="tab-btn" role="tab" data-tab="structural" aria-selected="false">Structural Validation</button>
      </div>

      <!-- Tab: Metabolic Modeling -->
      <div id="panel-metabolic" class="tab-panel active" role="tabpanel">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; padding-bottom:3rem; align-items:start;">
          <div>
            <h2 class="headline-sm">iJDZ836 Genome-Scale Metabolic Model</h2>
            <p style="color:#8B95A5; line-height:1.7; font-size:0.9375rem; margin-bottom:1.5rem;">
              The iJDZ836 model provides a comprehensive picture of <em>N. crassa</em> metabolism. We used it to predict growth rates on different carbon sources, identify essential genes, and simulate the metabolic impact of knockout combinations.
            </p>

            <div style="overflow-x:auto; border-radius:8px; border:1px solid #1F2937; margin-bottom:1.5rem;">
              <table class="data-table" style="min-width:360px;">
                <thead>
                  <tr><th>Model Property</th><th style="color:#00D4AA;">Value</th></tr>
                </thead>
                <tbody>
                  <tr><td>Total genes modeled</td><td class="highlight">836</td></tr>
                  <tr><td>Essential genes (~15.5%)</td><td class="highlight">~130</td></tr>
                  <tr><td>Carbon sources tested</td><td class="highlight">78</td></tr>
                  <tr><td>Carbon sources supporting growth</td><td class="highlight">24</td></tr>
                  <tr><td>Growth rate on xylose</td><td class="highlight">0.854 hr⁻¹</td></tr>
                  <tr><td>Growth rate on sucrose</td><td>0.305 hr⁻¹</td></tr>
                </tbody>
              </table>
            </div>

            <div style="background:rgba(0,212,170,0.06); border:1px solid rgba(0,212,170,0.2); border-radius:8px; padding:1rem;">
              <p style="font-size:0.875rem; color:#F8F9FA; margin:0; line-height:1.6;">
                <strong>Key finding:</strong> Xylose growth rate (0.854 hr⁻¹) is 2.8× higher than sucrose, confirming xylose as a preferred carbon source and the correct chassis feed for the chow reservoir.
              </p>
            </div>
          </div>

          <div>
            <h3 style="font-size:1rem; font-weight:600; color:#F8F9FA; margin:0 0 1rem;">Carbon Source Screen Results</h3>
            <!-- Visual bar chart of top carbon sources -->
            <div style="background:#111827; border:1px solid #1F2937; border-radius:8px; padding:1.25rem; margin-bottom:1.5rem;">
              {[
                { name: 'Xylose (chow)', value: 0.854, pct: 100, highlight: true },
                { name: 'Cellobiose', value: 0.72, pct: 84 },
                { name: 'Arabinose', value: 0.61, pct: 71 },
                { name: 'Sucrose', value: 0.305, pct: 36 },
                { name: 'Glucose', value: 0.28, pct: 33 },
              ].map(c => (
                <div style="margin-bottom:0.875rem;">
                  <div style="display:flex; justify-content:space-between; margin-bottom:0.3rem;">
                    <span style={`font-size:0.8125rem; font-weight:${c.highlight ? 600 : 400}; color:${c.highlight ? '#F8F9FA' : '#8B95A5'};`}>{c.name}</span>
                    <span style={`font-size:0.8125rem; font-weight:600; color:${c.highlight ? '#00D4AA' : '#8B95A5'};`}>{c.value} hr⁻¹</span>
                  </div>
                  <div class="progress-track" style="height:6px;">
                    <div class="progress-fill sci-bar" data-pct={c.pct}
                      style={`background:${c.highlight ? '#00D4AA' : '#374151'};`}></div>
                  </div>
                </div>
              ))}
            </div>

            <div class="card">
              <p style="font-size:0.75rem; font-weight:600; color:#8B95A5; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 0.75rem;">Gene Essentiality</p>
              <div style="display:flex; gap:1.5rem; align-items:center;">
                <div style="flex:1;">
                  <div style="display:flex; justify-content:space-between; margin-bottom:0.3rem;">
                    <span style="font-size:0.8125rem; color:#8B95A5;">Essential (~15.5%)</span>
                    <span style="font-size:0.8125rem; color:#EF4444; font-weight:600;">~130 genes</span>
                  </div>
                  <div class="progress-track"><div style="width:15.5%; background:#EF4444;" class="progress-fill sci-bar" data-pct="15.5"></div></div>
                </div>
                <div style="flex:1;">
                  <div style="display:flex; justify-content:space-between; margin-bottom:0.3rem;">
                    <span style="font-size:0.8125rem; color:#8B95A5;">Targetable</span>
                    <span style="font-size:0.8125rem; color:#00D4AA; font-weight:600;">~706 genes</span>
                  </div>
                  <div class="progress-track"><div style="width:84.5%;" class="progress-fill sci-bar" data-pct="84.5"></div></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Tab: Knockout Screen -->
      <div id="panel-knockout" class="tab-panel" role="tabpanel">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; padding-bottom:3rem; align-items:start;">
          <div>
            <h2 class="headline-sm">9,976 Knockout Pairs Screened</h2>
            <p style="color:#8B95A5; line-height:1.7; font-size:0.9375rem; margin-bottom:1.5rem;">
              We enumerated all viable double-knockout combinations from ~142 non-essential transporter and central carbon genes. Each pair was scored using the <strong style="color:#F8F9FA;">Composite Orthogonality Score (COS)</strong> — balancing sugar transport blocking against xylose growth fitness.
            </p>
            <p style="color:#8B95A5; line-height:1.7; font-size:0.9375rem; margin-bottom:1.5rem;">
              The top 50 candidates were classified into three phenotype tiers. Tier 1 (ranks 1–16) provides the best sugar blocking with ~30% WT xylose growth — a doubling time of ~2.7 hr, sufficient for robust chip colonization in 7 days.
            </p>

            <div style="overflow-x:auto; border-radius:8px; border:1px solid #1F2937;">
              <table class="data-table" style="min-width:400px;">
                <thead>
                  <tr><th>Tier</th><th>Ranks</th><th>Xylose growth</th><th>Sugar blocking</th><th>Use case</th></tr>
                </thead>
                <tbody>
                  <tr>
                    <td><span class="badge badge-cyan">Tier 1</span></td>
                    <td class="highlight">1–16</td>
                    <td>~30% WT</td>
                    <td style="color:#00D4AA;">Strong</td>
                    <td style="color:#F8F9FA; font-weight:500;">Recommended chassis</td>
                  </tr>
                  <tr>
                    <td><span class="badge badge-amber">Tier 2</span></td>
                    <td>17–32</td>
                    <td>Marginal</td>
                    <td style="color:#00D4AA;">Very strong</td>
                    <td>Aggressive blocking</td>
                  </tr>
                  <tr>
                    <td><span class="badge" style="background:rgba(139,149,165,0.1);color:#8B95A5;border:1px solid rgba(139,149,165,0.3);">Tier 3</span></td>
                    <td>33–50</td>
                    <td>Best WT-like</td>
                    <td>Moderate</td>
                    <td>Fitness-first applications</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div style="margin-top:1.25rem; background:rgba(0,212,170,0.06); border:1px solid rgba(0,212,170,0.2); border-radius:8px; padding:1rem;">
              <p style="font-size:0.875rem; color:#F8F9FA; margin:0; line-height:1.6;">
                <strong>COS methodology:</strong> The Composite Orthogonality Score weights sugar transport blocking (primary) against xylose fitness maintenance (secondary), giving a single ranked metric across all 9,976 pairs.
              </p>
            </div>
          </div>

          <div>
            <!-- Growth Phenotype Landscape visual -->
            <div class="card" style="padding:1.25rem; margin-bottom:1.25rem;">
              <p style="font-size:0.75rem; font-weight:600; color:#00D4AA; letter-spacing:0.1em; text-transform:uppercase; margin:0 0 1rem;">Growth Phenotype Landscape</p>
              <canvas id="ko-scatter" style="width:100%; height:220px; display:block; border-radius:6px;"></canvas>
              <p style="font-size:0.75rem; color:#8B95A5; margin:0.75rem 0 0; text-align:center;">X: Growth on sugar reagents · Y: Growth on xylose (chow) · Color: COS score</p>
            </div>

            <div class="card">
              <p style="font-size:0.75rem; font-weight:600; color:#8B95A5; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 1rem;">Screening Summary</p>
              <div style="display:flex; flex-direction:column; gap:0.75rem;">
                {[
                  { label: 'Total gene pairs evaluated', val: '9,976', c: '#00D4AA' },
                  { label: 'Non-essential transporter genes', val: '~142', c: '#F8F9FA' },
                  { label: 'Tier 1 candidates', val: '16 pairs', c: '#00D4AA' },
                  { label: 'Python code (modeling pipeline)', val: '7,600+ lines', c: '#F8F9FA' },
                ].map(r => (
                  <div style="display:flex; justify-content:space-between; align-items:center; padding:0.5rem 0; border-bottom:1px solid #1F2937;">
                    <span style="font-size:0.875rem; color:#8B95A5;">{r.label}</span>
                    <span style={`font-size:0.875rem; font-weight:600; color:${r.c};`}>{r.val}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Tab: Structural Validation -->
      <div id="panel-structural" class="tab-panel" role="tabpanel">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; padding-bottom:3rem; align-items:start;">
          <div>
            <h2 class="headline-sm">ColabFold Structural Validation</h2>
            <p style="color:#8B95A5; line-height:1.7; font-size:0.9375rem; margin-bottom:1.5rem;">
              Both valve components were predicted using ColabFold (AlphaFold2-based). High pLDDT scores (&gt;80) indicate confident structural predictions, validating the domain architectures before wet-lab synthesis.
            </p>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1.5rem;">
              <div style="text-align:center; padding:1.5rem; background:#111827; border:1px solid #1F2937; border-radius:8px;">
                <p style="font-size:3rem; font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display);">91</p>
                <p style="font-size:0.8125rem; color:#8B95A5; margin:0.25rem 0 0;">pLDDT — LOV2 domain</p>
                <p style="font-size:0.75rem; color:#00D4AA; margin:0.25rem 0 0;">High confidence</p>
              </div>
              <div style="text-align:center; padding:1.5rem; background:#111827; border:1px solid #1F2937; border-radius:8px;">
                <p style="font-size:3rem; font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display);">88</p>
                <p style="font-size:0.8125rem; color:#8B95A5; margin:0.25rem 0 0;">pLDDT — HEX1 domain</p>
                <p style="font-size:0.75rem; color:#00D4AA; margin:0.25rem 0 0;">High confidence</p>
              </div>
            </div>

            <div style="overflow-x:auto; border-radius:8px; border:1px solid #1F2937; margin-bottom:1.25rem;">
              <table class="data-table" style="min-width:400px;">
                <thead>
                  <tr><th>Construct</th><th>Size</th><th>pLDDT</th><th>Key structural feature</th></tr>
                </thead>
                <tbody>
                  <tr>
                    <td style="color:#F8F9FA; font-weight:500;">HEX1-LOV2 (CompA_v3)</td>
                    <td>35aa linker, 36.9 kDa</td>
                    <td class="highlight">91</td>
                    <td>LOV2 β-sheet + Jα helix intact</td>
                  </tr>
                  <tr>
                    <td style="color:#F8F9FA; font-weight:500;">SPA1-ePDZ (CompB)</td>
                    <td>358aa, 39.4 kDa</td>
                    <td class="highlight">88</td>
                    <td>PDZ binding groove correctly folded</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div style="background:rgba(245,166,35,0.06); border:1px solid rgba(245,166,35,0.2); border-radius:8px; padding:1rem;">
              <p style="font-size:0.8125rem; color:#F8F9FA; margin:0; line-height:1.6;">
                <strong>Next step:</strong> SEC-MALS (M4) will confirm oligomeric state of CompA_v3 with target R_h ≥ 28 nm, followed by BLI/SPR binding confirmation (M6) targeting K_d ≤ 1 µM in the lit state.
              </p>
            </div>
          </div>

          <div>
            <div class="card" style="padding:1.25rem; margin-bottom:1.25rem;">
              <p style="font-size:0.75rem; font-weight:600; color:#00D4AA; letter-spacing:0.1em; text-transform:uppercase; margin:0 0 1rem;">pLDDT Confidence Scale</p>
              <div style="display:flex; flex-direction:column; gap:0.75rem;">
                {[
                  { range: '> 90', label: 'Very high confidence', color: '#00D4AA', pct: 100 },
                  { range: '70–90', label: 'High confidence', color: '#2B7FFF', pct: 78 },
                  { range: '50–70', label: 'Moderate — flexible regions', color: '#F5A623', pct: 55 },
                  { range: '< 50', label: 'Low — disordered', color: '#EF4444', pct: 25 },
                ].map(s => (
                  <div>
                    <div style="display:flex; justify-content:space-between; margin-bottom:0.25rem;">
                      <span style={`font-size:0.8125rem; color:${s.color}; font-weight:600;`}>{s.range}</span>
                      <span style="font-size:0.8125rem; color:#8B95A5;">{s.label}</span>
                    </div>
                    <div class="progress-track" style="height:5px;">
                      <div class="progress-fill sci-bar" data-pct={s.pct} style={`background:${s.color};`}></div>
                    </div>
                  </div>
                ))}
              </div>
              <div style="margin-top:1.25rem; padding:0.75rem; background:#0B0F19; border-radius:6px; border:1px solid #1F2937;">
                <p style="font-size:0.8125rem; color:#8B95A5; margin:0;">
                  Our constructs score <span style="color:#00D4AA; font-weight:600;">91</span> and <span style="color:#00D4AA; font-weight:600;">88</span> — both in the "very high confidence" band, meaning the core functional domains are confidently predicted.
                </p>
              </div>
            </div>

            <div class="card">
              <p style="font-size:0.75rem; font-weight:600; color:#8B95A5; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 0.75rem;">Fusion Protein Geometry</p>
              <div style="display:flex; flex-direction:column; gap:0.625rem;">
                {[
                  { label: 'N-terminus', val: 'HEX1 Woronin body core (176aa)', c: '#F8F9FA' },
                  { label: 'Linker', val: '35aa flexible (Gly-Ser)', c: '#8B95A5' },
                  { label: 'C-terminus', val: 'LOV2+Jα from WC-1 (NCU02356)', c: '#F8F9FA' },
                  { label: 'Total MW', val: '36.9 kDa (CompA), 39.4 kDa (CompB)', c: '#00D4AA' },
                ].map(r => (
                  <div style="display:flex; justify-content:space-between; padding:0.5rem 0; border-bottom:1px solid #1F2937;">
                    <span style="font-size:0.8125rem; color:#8B95A5;">{r.label}</span>
                    <span style={`font-size:0.8125rem; color:${r.c}; font-weight:500;`}>{r.val}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 12-Month Milestone Timeline -->
  <section class="bg-surface">
    <div class="container">
      <div class="reveal" style="text-align:center; margin-bottom:3rem;">
        <span class="section-label">12-Month Milestones</span>
        <h2 class="headline">With $1.5M Seed</h2>
        <p class="subhead" style="max-width:540px; margin:0 auto;">Six clear milestones from chassis construction to first customer. Each has a concrete, measurable success metric.</p>
      </div>

      <!-- Desktop timeline -->
      <div class="reveal" style="position:relative; padding:0 0 2rem;">
        <!-- Connector line -->
        <div style="position:absolute; top:28px; left:calc(8.33% + 24px); right:calc(8.33% + 24px); height:2px; background:linear-gradient(to right, #00D4AA, #F5A623); opacity:0.4; display:none;" id="timeline-line"></div>

        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem;">
          {milestones.map((m, i) => (
            <div class="card" style={`border-top:2px solid ${i < 4 ? '#00D4AA' : '#F5A623'}; position:relative;`}>
              <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.875rem;">
                <span style={`display:inline-flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:50%; font-size:0.75rem; font-weight:700; flex-shrink:0; background:${i < 4 ? 'rgba(0,212,170,0.15)' : 'rgba(245,166,35,0.15)'}; color:${i < 4 ? '#00D4AA' : '#F5A623'}; border:1px solid ${i < 4 ? 'rgba(0,212,170,0.3)' : 'rgba(245,166,35,0.3)'};`}>
                  {m.mo}
                </span>
                <h3 style="font-size:0.9375rem; font-weight:600; color:#F8F9FA; margin:0; line-height:1.3;">{m.label}</h3>
              </div>
              <div style={`padding:0.625rem 0.875rem; background:${i < 4 ? 'rgba(0,212,170,0.06)' : 'rgba(245,166,35,0.06)'}; border-radius:6px; border:1px solid ${i < 4 ? 'rgba(0,212,170,0.15)' : 'rgba(245,166,35,0.15)'};`}>
                <p style="font-size:0.8125rem; color:#8B95A5; margin:0; font-family:var(--font-mono);">{m.metric}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Publications placeholder -->
  <section class="bg-dark">
    <div class="container" style="max-width:720px; margin:0 auto; text-align:center;">
      <div class="reveal">
        <span class="section-label">Publications</span>
        <h2 class="headline">Manuscript in Preparation</h2>
        <p class="subhead" style="margin-bottom:2rem;">A full methods paper describing the metabolic orthogonality screening pipeline, optogenetic valve design, and H-tree scaffold geometry is in preparation for submission to a peer-reviewed journal.</p>
        <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
          <div class="card" style="text-align:left; max-width:460px; padding:1.25rem;">
            <p style="font-size:0.75rem; color:#8B95A5; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 0.5rem;">In Preparation</p>
            <p style="color:#F8F9FA; font-size:0.9375rem; font-weight:500; margin:0 0 0.5rem; line-height:1.5;">"Self-assembling microfluidic chips via metabolically orthogonal <em>Neurospora crassa</em> with optogenetic flow control"</p>
            <p style="color:#8B95A5; font-size:0.8125rem; margin:0;">McKenna, M. — <em>Target: Nature Biotechnology / Lab on a Chip</em></p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
// Tabs
document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected','false'); });
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    btn.setAttribute('aria-selected','true');
    document.getElementById('panel-' + btn.dataset.tab)?.classList.add('active');
    animateBars();
  });
});

// Animate progress bars on scroll
function animateBars() {
  document.querySelectorAll<HTMLElement>('.sci-bar').forEach(el => {
    el.style.width = (el.dataset.pct ?? '0') + '%';
  });
}
const obs = new IntersectionObserver(entries => {
  if (entries[0].isIntersecting) { animateBars(); obs.disconnect(); }
}, { threshold: 0.2 });
const firstPanel = document.getElementById('panel-metabolic');
if (firstPanel) obs.observe(firstPanel);

// KO scatter plot
(function() {
  const canvas = document.getElementById('ko-scatter') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  function draw() {
    const W = canvas.offsetWidth, H = canvas.offsetHeight;
    canvas.width = W; canvas.height = H;
    ctx.fillStyle = '#0B0F19';
    ctx.fillRect(0, 0, W, H);

    const pad = { t: 12, r: 12, b: 28, l: 32 };
    const mW = W - pad.l - pad.r;
    const mH = H - pad.t - pad.b;

    // Axes
    ctx.strokeStyle = '#1F2937'; ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(pad.l, pad.t); ctx.lineTo(pad.l, pad.t + mH);
    ctx.lineTo(pad.l + mW, pad.t + mH);
    ctx.stroke();

    // Labels
    ctx.fillStyle = '#4B5563'; ctx.font = '9px Inter, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('Growth on sugar reagents →', pad.l + mW / 2, H - 4);
    ctx.save(); ctx.translate(10, pad.t + mH / 2);
    ctx.rotate(-Math.PI/2);
    ctx.fillText('← Growth on xylose (chow)', 0, 0);
    ctx.restore();

    // Generate synthetic scatter points mimicking the pitch deck distribution
    const rng = (seed: number) => { let x = Math.sin(seed) * 10000; return x - Math.floor(x); };
    const points: {x: number, y: number, cos: number, top: boolean}[] = [];
    for (let i = 0; i < 9976; i++) {
      const x = 2 + rng(i * 3.7) * 6;
      const baseY = 0.15 + rng(i * 2.3) * 0.7;
      const y = baseY - Math.max(0, (x - 4) * 0.07);
      const cos = Math.max(0, (1 - x / 8) * 0.4 + y * 0.3 + rng(i * 5.1) * 0.15);
      points.push({ x, y: Math.max(0.05, y), cos, top: i < 16 });
    }

    // Draw points (subsample for performance)
    const step = Math.max(1, Math.floor(points.length / 600));
    points.forEach((p, i) => {
      if (i % step !== 0 && !p.top) return;
      const cx = pad.l + ((p.x - 2) / 6) * mW;
      const cy = pad.t + mH - (p.y / 0.85) * mH * 0.9;
      const alpha = 0.15 + p.cos * 0.6;
      const r = p.top ? 4 : 1.5;
      const hue = Math.round(160 - p.cos * 120);
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.fillStyle = p.top ? '#00D4AA' : `hsla(${hue}, 70%, 55%, ${alpha})`;
      ctx.fill();
    });

    // Top 16 label
    ctx.fillStyle = '#00D4AA';
    ctx.font = 'bold 9px Inter, sans-serif';
    ctx.textAlign = 'left';
    ctx.fillText('★ Top 50 candidates (COS)', pad.l + 8, pad.t + 12);
  }

  const o = new IntersectionObserver(e => { if (e[0].isIntersecting) { draw(); o.disconnect(); } }, { threshold: 0.1 });
  o.observe(canvas);
  window.addEventListener('resize', draw);
})();
</script>
