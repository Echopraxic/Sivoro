---
import BaseLayout from '../layouts/BaseLayout.astro';

const milestones = [
  { mo: 'M2', label: 'Construct six-gene chassis', metric: 'PCR-verified knockouts', done: false },
  { mo: 'M4', label: 'SEC-MALS on CompA_v3', metric: 'R_h ≥ 28 nm', done: false },
  { mo: 'M6', label: 'BLI/SPR Jα-ePDZ binding confirmed', metric: 'K_d ≤ 1 µM lit, ≥10× dark/lit ratio', done: false },
  { mo: 'M8', label: 'Valve functional (microscopy)', metric: '≥50% pore closure at 450 nm', done: false },
  { mo: 'M10', label: 'Prototype chip colonization', metric: 'Fluorescent flow through network', done: false },
  { mo: 'M12', label: 'First customer — academic beta site', metric: 'LOI from 3 labs', done: false },
];

// Six-gene chassis, described by function (not locus ID) per IP strategy.
const chassis = [
  { n: 1, role: 'Central glycolysis enzyme', why: 'Knocked out to break glucose-route flux — forces dependence on the xylose chow feed.', tag: 'Metabolic block', color: '#00D4AA' },
  { n: 2, role: 'Respiratory-chain subunit', why: 'Paired knockout that deepens reagent blocking while preserving residual xylose growth.', tag: 'Metabolic block', color: '#00D4AA' },
  { n: 3, role: 'Carbon-catabolite-repression regulator', why: 'Removed to lift repression on xylose utilization — a kinetic growth benefit on the chow source.', tag: 'Kinetic tuning', color: '#2B7FFF' },
  { n: 4, role: 'Aerial-hyphae suppressor (i)', why: 'Keeps growth confined to the channel plane so the network stays a clean fluidic conduit.', tag: 'Morphology', color: '#F5A623' },
  { n: 5, role: 'Aerial-hyphae suppressor (ii)', why: 'Second morphology control that reinforces channel integrity during colonization.', tag: 'Morphology', color: '#F5A623' },
  { n: 6, role: 'Blue-light photoreceptor', why: 'Removed so the native light response cannot interfere transcriptionally with the 450 nm optogenetic valve.', tag: 'Optogenetic isolation', color: '#8B5CF6' },
];
---

<BaseLayout
  title="Science | Sivoro Microfluidics"
  description="Patent-validated computational pipeline: iJDZ836 metabolic model, 10,440 knockout combinations screened, 16 chip-eligible strains, Composite Orthogonality Score, and Aspergillus nidulans cross-species validation. ColabFold pLDDT 91/88/76."
  keywords="chip-eligible strains, Composite Orthogonality Score, COS, iJDZ836 metabolic model, Neurospora crassa knockout screen, Aspergillus nidulans cross-species, iMA871, ColabFold pLDDT, metabolic orthogonality, synthetic biology validation, microfluidics research"
>
  <!-- Hero -->
  <section style="padding-top:calc(64px + 5rem); padding-bottom:4rem; background:#0B0F19; border-bottom:1px solid #1F2937;">
    <div class="container">
      <div class="reveal" style="max-width:760px;">
        <span class="section-label">Science</span>
        <h1 class="headline" style="font-size:clamp(2rem,4.5vw,3.75rem);">Computational Validation Complete</h1>
        <p class="subhead">From a genome-scale metabolic model to 16 chip-eligible strains, a structurally validated optogenetic valve, and a cross-species proof point — every computational phase is done and now backed by a filed provisional patent.</p>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section style="padding:2.5rem 0; background:#111827; border-bottom:1px solid #1F2937;">
    <div class="container">
      <div class="reveal-stagger reveal" style="display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; text-align:center;">
        <div>
          <p style="font-size:clamp(1.75rem,3.6vw,2.75rem); font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display);">10,440</p>
          <p style="font-size:0.8125rem; color:#8B95A5; margin:0.25rem 0 0;">KO combinations screened</p>
        </div>
        <div>
          <p style="font-size:clamp(1.75rem,3.6vw,2.75rem); font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display);">16</p>
          <p style="font-size:0.8125rem; color:#8B95A5; margin:0.25rem 0 0;">Chip-eligible strains</p>
        </div>
        <div>
          <p style="font-size:clamp(1.75rem,3.6vw,2.75rem); font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display);">2</p>
          <p style="font-size:0.8125rem; color:#8B95A5; margin:0.25rem 0 0;">Species validated</p>
        </div>
        <div>
          <p style="font-size:clamp(1.75rem,3.6vw,2.75rem); font-weight:700; color:#F5A623; margin:0; font-family:var(--font-display);">91/88</p>
          <p style="font-size:0.8125rem; color:#8B95A5; margin:0.25rem 0 0;">pLDDT — LOV2 / HEX1</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tabbed data sections -->
  <section class="bg-dark" style="padding-top:3rem;">
    <div class="container">
      <div class="tab-list" role="tablist" aria-label="Science data">
        <button class="tab-btn active" role="tab" data-tab="metabolic" aria-selected="true">Metabolic Modeling</button>
        <button class="tab-btn" role="tab" data-tab="strains" aria-selected="false">Chip-Eligible Strains</button>
        <button class="tab-btn" role="tab" data-tab="crossspecies" aria-selected="false">Cross-Species Validation</button>
        <button class="tab-btn" role="tab" data-tab="structural" aria-selected="false">Structural Validation</button>
      </div>

      <!-- Tab: Metabolic Modeling -->
      <div id="panel-metabolic" class="tab-panel active" role="tabpanel">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; padding-bottom:3rem; align-items:start;">
          <div>
            <h2 class="headline-sm">iJDZ836 Genome-Scale Metabolic Model</h2>
            <p style="color:#8B95A5; line-height:1.7; font-size:0.9375rem; margin-bottom:1.5rem;">
              The iJDZ836 model (836 genes, ~1,200 reactions) provides a comprehensive picture of <em>N. crassa</em> metabolism. Full flux-balance analysis predicted growth across 78 candidate carbon sources and quantified the metabolic impact of every knockout combination before any wet-lab work.
            </p>

            <div style="overflow-x:auto; border-radius:8px; border:1px solid #1F2937; margin-bottom:1.5rem;">
              <table class="data-table" style="min-width:360px;">
                <thead>
                  <tr><th>Model Property</th><th style="color:#00D4AA;">Value</th></tr>
                </thead>
                <tbody>
                  <tr><td>Total genes modeled</td><td class="highlight">836</td></tr>
                  <tr><td>Metabolic reactions</td><td class="highlight">~1,200</td></tr>
                  <tr><td>Carbon sources tested</td><td class="highlight">78</td></tr>
                  <tr><td>Carbon sources supporting growth</td><td class="highlight">24</td></tr>
                  <tr><td>Permissive chow source</td><td class="highlight">Xylose</td></tr>
                  <tr><td>Pairwise KO combinations</td><td>10,440</td></tr>
                </tbody>
              </table>
            </div>

            <div style="background:rgba(0,212,170,0.06); border:1px solid rgba(0,212,170,0.2); border-radius:8px; padding:1rem;">
              <p style="font-size:0.875rem; color:#F8F9FA; margin:0; line-height:1.6;">
                <strong>Key finding:</strong> Of 78 carbon sources, only 24 support growth. Xylose is selected as the permissive chow feed — knockouts then block the common reagent sugars while preserving xylose utilization, the basis of metabolic orthogonality.
              </p>
            </div>
          </div>

          <div>
            <h3 style="font-size:1rem; font-weight:600; color:#F8F9FA; margin:0 0 1rem;">Carbon Source Preference (relative)</h3>
            <!-- Visual bar chart of relative carbon preference -->
            <div style="background:#111827; border:1px solid #1F2937; border-radius:8px; padding:1.25rem; margin-bottom:1.5rem;">
              {[
                { name: 'Xylose (chow)', pct: 100, highlight: true },
                { name: 'Cellobiose', pct: 84 },
                { name: 'Arabinose', pct: 71 },
                { name: 'Sucrose', pct: 36 },
                { name: 'Glucose', pct: 33 },
              ].map(c => (
                <div style="margin-bottom:0.875rem;">
                  <div style="display:flex; justify-content:space-between; margin-bottom:0.3rem;">
                    <span style={`font-size:0.8125rem; font-weight:${c.highlight ? 600 : 400}; color:${c.highlight ? '#F8F9FA' : '#8B95A5'};`}>{c.name}</span>
                    <span style={`font-size:0.8125rem; font-weight:600; color:${c.highlight ? '#00D4AA' : '#8B95A5'};`}>{c.pct}%</span>
                  </div>
                  <div class="progress-track" style="height:6px;">
                    <div class="progress-fill sci-bar" data-pct={c.pct}
                      style={`background:${c.highlight ? '#00D4AA' : '#374151'};`}></div>
                  </div>
                </div>
              ))}
              <p style="font-size:0.6875rem; color:#4B5563; margin:0.5rem 0 0;">Relative predicted growth preference, normalized to xylose.</p>
            </div>

            <div class="card">
              <p style="font-size:0.75rem; font-weight:600; color:#8B95A5; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 0.75rem;">Screening Funnel</p>
              <div style="display:flex; flex-direction:column; gap:0.75rem;">
                {[
                  { label: '145-gene candidate pool', val: '145', c: '#F8F9FA' },
                  { label: 'Pairwise KO combinations', val: '10,440', c: '#00D4AA' },
                  { label: 'Chip-eligible (RBS ≥ 0.868)', val: '16', c: '#00D4AA' },
                  { label: 'Pipeline code', val: '7,600+ lines', c: '#F8F9FA' },
                ].map(r => (
                  <div style="display:flex; justify-content:space-between; align-items:center; padding:0.5rem 0; border-bottom:1px solid #1F2937;">
                    <span style="font-size:0.875rem; color:#8B95A5;">{r.label}</span>
                    <span style={`font-size:0.875rem; font-weight:600; color:${r.c};`}>{r.val}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Tab: Chip-Eligible Strains -->
      <div id="panel-strains" class="tab-panel" role="tabpanel">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; padding-bottom:2rem; align-items:start;">
          <div>
            <h2 class="headline-sm">16 Chip-Eligible Strains</h2>
            <p style="color:#8B95A5; line-height:1.7; font-size:0.9375rem; margin-bottom:1.5rem;">
              From <strong style="color:#F8F9FA;">10,440 pairwise knockout combinations</strong> across a 145-gene pool, each pair was ranked by the <strong style="color:#F8F9FA;">Composite Orthogonality Score (COS)</strong>. Sixteen pairs clear the chip-integration threshold of <strong style="color:#00D4AA;">RBS ≥ 0.868</strong> — these are the chassis candidates that can colonize a chip while blocking reagent metabolism.
            </p>

            <div style="background:rgba(0,212,170,0.06); border:1px solid rgba(0,212,170,0.2); border-radius:8px; padding:1rem 1.25rem; margin-bottom:1.5rem;">
              <p style="font-size:0.8125rem; font-weight:600; color:#00D4AA; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 0.5rem;">Composite Orthogonality Score</p>
              <p style="font-family:var(--font-mono); font-size:1.0625rem; color:#F8F9FA; margin:0 0 0.625rem; text-align:center;">COS = √( CPS × RBS )</p>
              <p style="font-size:0.8125rem; color:#8B95A5; margin:0; line-height:1.6;">
                <strong style="color:#F8F9FA;">CPS</strong> (Chow Preservation Score) measures retained xylose growth. <strong style="color:#F8F9FA;">RBS</strong> (Reagent Block Score) = 1 − (reagent growth ÷ WT xylose growth). The geometric mean rewards pairs that block reagents <em>and</em> stay alive on chow.
              </p>
            </div>

            <!-- Exemplary pair metric card -->
            <div class="card" style="border-top:2px solid #00D4AA;">
              <p style="font-size:0.75rem; font-weight:600; color:#00D4AA; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 0.875rem;">Exemplary Chip-Eligible Pair</p>
              <p style="font-size:0.875rem; color:#8B95A5; line-height:1.6; margin:0 0 1rem;">A central-glycolysis enzyme knockout paired with a respiratory-chain subunit knockout — strong reagent blocking with enough residual xylose growth to colonize.</p>
              <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:0.75rem;">
                {[
                  { val: '0.185', label: 'CPS', c: '#F8F9FA' },
                  { val: '0.868', label: 'RBS', c: '#00D4AA' },
                  { val: '~18.5%', label: 'Residual xylose vs WT', c: '#F5A623' },
                ].map(m => (
                  <div style="text-align:center; padding:0.75rem 0.25rem; background:#0B0F19; border:1px solid #1F2937; border-radius:6px;">
                    <p style={`font-size:1.25rem; font-weight:700; color:${m.c}; margin:0; font-family:var(--font-display);`}>{m.val}</p>
                    <p style="font-size:0.6875rem; color:#8B95A5; margin:0.25rem 0 0; line-height:1.3;">{m.label}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div>
            <!-- COS Pareto-frontier plot -->
            <div class="card" style="padding:1.25rem; margin-bottom:1.25rem;">
              <p style="font-size:0.75rem; font-weight:600; color:#00D4AA; letter-spacing:0.1em; text-transform:uppercase; margin:0 0 1rem;">COS Tradeoff — CPS vs RBS</p>
              <canvas id="cos-pareto" style="width:100%; height:300px; display:block; border-radius:6px;"></canvas>
              <p style="font-size:0.75rem; color:#8B95A5; margin:0.75rem 0 0; text-align:center; line-height:1.5;">
                X: Chow Preservation (CPS) · Y: Reagent Blocking (RBS) · <span style="color:#00D4AA;">●</span> 16 chip-eligible (RBS ≥ 0.868)
              </p>
            </div>

            <div style="background:rgba(245,166,35,0.06); border:1px solid rgba(245,166,35,0.2); border-radius:8px; padding:1rem;">
              <p style="font-size:0.8125rem; color:#F8F9FA; margin:0; line-height:1.6;">
                <strong>Honest constraint:</strong> no pair reaches the upper-right corner — none achieves both CPS &gt; 0.5 and RBS &gt; 0.8 at once. This is an inherent biological tradeoff: deeper reagent blocking costs chow fitness. The 16 chip-eligible strains are the best available balance.
              </p>
            </div>
          </div>
        </div>

        <!-- Six-gene chassis explorer -->
        <div style="padding-bottom:3rem;">
          <h3 style="font-size:1.125rem; font-weight:600; color:#F8F9FA; margin:0 0 0.5rem;">The Six-Gene Chassis</h3>
          <p style="color:#8B95A5; font-size:0.9375rem; line-height:1.7; margin:0 0 1.5rem; max-width:680px;">A chip-eligible pair is only the metabolic core. The full chassis layers in four more knockouts for kinetics, morphology, and optogenetic isolation — six engineered edits that together make a clean, light-controllable fluidic network.</p>
          <div class="grid-3 reveal-stagger">
            {chassis.map(g => (
              <div class="card" style={`border-left:3px solid ${g.color};`}>
                <div style="display:flex; align-items:center; gap:0.625rem; margin-bottom:0.625rem;">
                  <span style={`display:inline-flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:50%; font-size:0.8125rem; font-weight:700; flex-shrink:0; background:${g.color}1a; color:${g.color}; border:1px solid ${g.color}40;`}>{g.n}</span>
                  <span style={`font-size:0.6875rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; color:${g.color};`}>{g.tag}</span>
                </div>
                <p style="font-size:0.9375rem; font-weight:600; color:#F8F9FA; margin:0 0 0.375rem; line-height:1.3;">{g.role}</p>
                <p style="font-size:0.8125rem; color:#8B95A5; line-height:1.6; margin:0;">{g.why}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Tab: Cross-Species Validation -->
      <div id="panel-crossspecies" class="tab-panel" role="tabpanel">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; padding-bottom:3rem; align-items:start;">
          <div>
            <h2 class="headline-sm">Validated in a Second Species</h2>
            <p style="color:#8B95A5; line-height:1.7; font-size:0.9375rem; margin-bottom:1.5rem;">
              Metabolic orthogonality is a <strong style="color:#F8F9FA;">platform strategy, not a one-organism trick</strong>. The same approach was re-run <em>in silico</em> on <em>Aspergillus nidulans</em> using the published <strong style="color:#F8F9FA;">iMA871</strong> model (871 genes) — a fungus separated from <em>N. crassa</em> by roughly <strong style="color:#00D4AA;">170 million years</strong> of evolution.
            </p>
            <p style="color:#8B95A5; line-height:1.7; font-size:0.9375rem; margin-bottom:1.5rem;">
              Orthologous knockouts (a sugar transporter + a central-carbon aldolase, identified by reciprocal BLASTP) reproduce the xylose-selective phenotype — and actually block reagents <em>more</em> strongly than the <em>N. crassa</em> equivalent.
            </p>

            <div style="overflow-x:auto; border-radius:8px; border:1px solid #1F2937; margin-bottom:1.25rem;">
              <table class="data-table" style="min-width:380px;">
                <thead>
                  <tr><th><em>A. nidulans</em> double KO</th><th style="color:#00D4AA;">Result</th></tr>
                </thead>
                <tbody>
                  <tr><td>Growth on xylose</td><td class="highlight">0.198 h⁻¹ (27% WT)</td></tr>
                  <tr><td>Growth on glucose</td><td class="highlight">0.031 h⁻¹ (4.2% WT)</td></tr>
                  <tr><td>Reagent blocking</td><td class="highlight">95.8%</td></tr>
                  <tr><td>CPS</td><td>0.270</td></tr>
                  <tr><td>RBS</td><td style="color:#00D4AA;">0.958</td></tr>
                  <tr><td>COS</td><td class="highlight">0.508</td></tr>
                </tbody>
              </table>
            </div>

            <div style="background:rgba(0,212,170,0.06); border:1px solid rgba(0,212,170,0.2); border-radius:8px; padding:1rem;">
              <p style="font-size:0.875rem; color:#F8F9FA; margin:0; line-height:1.6;">
                <strong>Why it matters:</strong> <em>A. nidulans</em> clears the chip-integration threshold (RBS 0.958) where <em>N. crassa</em> falls short — direct evidence the strategy generalizes and the addressable organism set is broad.
              </p>
            </div>
          </div>

          <div>
            <!-- Cross-species comparison viz -->
            <div class="card" style="padding:1.25rem; margin-bottom:1.25rem;">
              <p style="font-size:0.75rem; font-weight:600; color:#00D4AA; letter-spacing:0.1em; text-transform:uppercase; margin:0 0 1.25rem;">Composite Orthogonality Score</p>
              <div style="display:flex; flex-direction:column; gap:1.25rem;">
                {[
                  { sp: 'A. nidulans', model: 'iMA871', cos: 0.508, rbs: 0.958, pct: 100, lead: true },
                  { sp: 'N. crassa', model: 'iJDZ836', cos: 0.499, rbs: 0.750, pct: 98 },
                ].map(s => (
                  <div>
                    <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:0.4rem;">
                      <span style={`font-size:0.9375rem; font-weight:600; font-style:italic; color:${s.lead ? '#00D4AA' : '#F8F9FA'};`}>{s.sp}</span>
                      <span style="font-size:0.6875rem; color:#4B5563; font-family:var(--font-mono);">{s.model}</span>
                    </div>
                    <div class="progress-track" style="height:26px; border-radius:6px;">
                      <div class="progress-fill sci-bar" data-pct={s.pct} style={`background:${s.lead ? 'linear-gradient(90deg,#00D4AA,#2B7FFF)' : '#374151'}; border-radius:6px; display:flex; align-items:center; justify-content:flex-end; padding-right:0.625rem;`}>
                        <span style="font-size:0.8125rem; font-weight:700; color:#0B0F19; font-family:var(--font-display);">COS {s.cos}</span>
                      </div>
                    </div>
                    <p style="font-size:0.75rem; color:#8B95A5; margin:0.3rem 0 0;">Reagent Block Score: <span style={`color:${s.lead ? '#00D4AA' : '#8B95A5'}; font-weight:600;`}>{s.rbs}</span></p>
                  </div>
                ))}
              </div>
            </div>

            <div class="card">
              <p style="font-size:0.75rem; font-weight:600; color:#8B95A5; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 0.75rem;">Evolutionary Distance</p>
              <div style="display:flex; align-items:center; gap:1rem;">
                <div style="text-align:center; flex:1;">
                  <p style="font-size:0.875rem; font-style:italic; color:#F8F9FA; margin:0;">N. crassa</p>
                </div>
                <div style="flex:2; text-align:center;">
                  <div style="height:2px; background:linear-gradient(90deg,#00D4AA,#F5A623); position:relative; margin:0.75rem 0;">
                    <span style="position:absolute; top:-1.4rem; left:50%; transform:translateX(-50%); font-size:0.875rem; font-weight:700; color:#F5A623; font-family:var(--font-display); white-space:nowrap;">~170M yrs</span>
                  </div>
                </div>
                <div style="text-align:center; flex:1;">
                  <p style="font-size:0.875rem; font-style:italic; color:#F8F9FA; margin:0;">A. nidulans</p>
                </div>
              </div>
              <p style="font-size:0.8125rem; color:#8B95A5; margin:1rem 0 0; line-height:1.6; text-align:center;">Two genera, ~170M years apart — the same orthogonality phenotype is reachable in both.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Tab: Structural Validation -->
      <div id="panel-structural" class="tab-panel" role="tabpanel">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; padding-bottom:3rem; align-items:start;">
          <div>
            <h2 class="headline-sm">ColabFold Structural Validation</h2>
            <p style="color:#8B95A5; line-height:1.7; font-size:0.9375rem; margin-bottom:1.5rem;">
              Both valve components were predicted with ColabFold (AlphaFold2-based). High pLDDT scores (&gt;80) on the functional domains validate the architecture before any wet-lab synthesis.
            </p>

            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:0.75rem; margin-bottom:1.5rem;">
              <div style="text-align:center; padding:1.25rem 0.5rem; background:#111827; border:1px solid #1F2937; border-radius:8px;">
                <p style="font-size:2.5rem; font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display);">91</p>
                <p style="font-size:0.75rem; color:#8B95A5; margin:0.25rem 0 0;">LOV2 domain</p>
                <p style="font-size:0.6875rem; color:#00D4AA; margin:0.2rem 0 0;">Very high</p>
              </div>
              <div style="text-align:center; padding:1.25rem 0.5rem; background:#111827; border:1px solid #1F2937; border-radius:8px;">
                <p style="font-size:2.5rem; font-weight:700; color:#00D4AA; margin:0; font-family:var(--font-display);">88</p>
                <p style="font-size:0.75rem; color:#8B95A5; margin:0.25rem 0 0;">HEX1 domain</p>
                <p style="font-size:0.6875rem; color:#00D4AA; margin:0.2rem 0 0;">Very high</p>
              </div>
              <div style="text-align:center; padding:1.25rem 0.5rem; background:#111827; border:1px solid #1F2937; border-radius:8px;">
                <p style="font-size:2.5rem; font-weight:700; color:#F5A623; margin:0; font-family:var(--font-display);">76</p>
