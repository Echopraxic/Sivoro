<script>
// Tabs
document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected','false'); });
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    btn.setAttribute('aria-selected','true');
    document.getElementById('panel-' + btn.dataset.tab)?.classList.add('active');
    animateBars();
    drawPareto();
  });
});

// Animate progress bars on scroll
function animateBars() {
  document.querySelectorAll<HTMLElement>('.sci-bar').forEach(el => {
    el.style.width = (el.dataset.pct ?? '0') + '%';
  });
}
const obs = new IntersectionObserver(entries => {
  if (entries[0].isIntersecting) { animateBars(); obs.disconnect(); }
}, { threshold: 0.2 });
const firstPanel = document.getElementById('panel-metabolic');
if (firstPanel) obs.observe(firstPanel);

// COS Pareto-frontier plot
function drawPareto() {
  const canvas = document.getElementById('cos-pareto') as HTMLCanvasElement | null;
  if (!canvas || !canvas.offsetWidth) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const W = canvas.offsetWidth, H = canvas.offsetHeight;
  canvas.width = W; canvas.height = H;
  ctx.fillStyle = '#0B0F19';
  ctx.fillRect(0, 0, W, H);

  const pad = { t: 16, r: 16, b: 34, l: 40 };
  const mW = W - pad.l - pad.r;
  const mH = H - pad.t - pad.b;
  const X = (v: number) => pad.l + v * mW;            // CPS 0..1
  const Y = (v: number) => pad.t + mH - v * mH;        // RBS 0..1

  // Shade the unreachable upper-right quadrant (CPS>0.5 && RBS>0.8)
  ctx.fillStyle = 'rgba(245,166,35,0.06)';
  ctx.fillRect(X(0.5), pad.t, X(1) - X(0.5), Y(0.8) - pad.t);
  ctx.strokeStyle = 'rgba(245,166,35,0.35)';
  ctx.setLineDash([4, 3]);
  ctx.strokeRect(X(0.5), pad.t, X(1) - X(0.5), Y(0.8) - pad.t);
  ctx.setLineDash([]);
  ctx.fillStyle = 'rgba(245,166,35,0.8)';
  ctx.font = '9px Inter, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('unreachable', X(0.75), pad.t + 14);

  // RBS >= 0.868 threshold line
  ctx.strokeStyle = 'rgba(0,212,170,0.45)';
  ctx.setLineDash([5, 4]);
  ctx.beginPath();
  ctx.moveTo(pad.l, Y(0.868));
  ctx.lineTo(pad.l + mW, Y(0.868));
  ctx.stroke();
  ctx.setLineDash([]);
  ctx.fillStyle = '#00D4AA';
  ctx.textAlign = 'left';
  ctx.fillText('RBS ≥ 0.868 → chip-eligible', pad.l + 4, Y(0.868) - 5);

  // Axes
  ctx.strokeStyle = '#1F2937'; ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(pad.l, pad.t); ctx.lineTo(pad.l, pad.t + mH);
  ctx.lineTo(pad.l + mW, pad.t + mH);
  ctx.stroke();

  // Axis labels
  ctx.fillStyle = '#4B5563'; ctx.font = '9px Inter, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('Chow Preservation (CPS) →', pad.l + mW / 2, H - 6);
  ctx.save(); ctx.translate(12, pad.t + mH / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillText('Reagent Blocking (RBS) →', 0, 0);
  ctx.restore();

  // Candidate cloud along an inverse tradeoff frontier (deterministic)
  const rng = (s: number) => { const x = Math.sin(s) * 10000; return x - Math.floor(x); };
  for (let i = 0; i < 900; i++) {
    const cps = 0.04 + rng(i * 3.7) * 0.92;
    // frontier: higher CPS -> lower max RBS; scatter below it
    const frontier = 1.0 - cps * 0.78;
    const rbs = Math.max(0.05, frontier - rng(i * 2.3) * 0.55);
    ctx.beginPath();
    ctx.arc(X(cps), Y(rbs), 1.4, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(139,149,165,0.28)';
    ctx.fill();
  }

  // The 16 chip-eligible strains: RBS >= 0.868, low CPS (per patent tradeoff)
  for (let i = 0; i < 16; i++) {
    const cps = 0.12 + rng(i * 7.13) * 0.12;        // ~0.12–0.24
    const rbs = 0.868 + rng(i * 4.9) * 0.085;        // 0.868–0.953
    ctx.beginPath();
    ctx.arc(X(cps), Y(rbs), 4, 0, Math.PI * 2);
    ctx.fillStyle = '#00D4AA';
    ctx.fill();
    ctx.strokeStyle = 'rgba(0,212,170,0.35)';
    ctx.lineWidth = 4;
    ctx.stroke();
    ctx.lineWidth = 1;
  }

  // Exemplary pair marker (CPS 0.185, RBS 0.868)
  ctx.beginPath();
  ctx.arc(X(0.185), Y(0.868), 5.5, 0, Math.PI * 2);
  ctx.fillStyle = '#F5A623';
  ctx.fill();
  ctx.fillStyle = '#F5A623';
  ctx.font = 'bold 9px Inter, sans-serif';
  ctx.textAlign = 'left';
  ctx.fillText('exemplary pair', X(0.185) + 9, Y(0.868) + 3);
}

const pObs = new IntersectionObserver(e => { if (e[0].isIntersecting) drawPareto(); }, { threshold: 0.1 });
const pCanvas = document.getElementById('cos-pareto');
if (pCanvas) pObs.observe(pCanvas);
window.addEventListener('resize', drawPareto);
</script>
