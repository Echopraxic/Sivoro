</BaseLayout>

<script>
// ─── Tab switching ────────────────────────────────────────────────
document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach((btn) => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach((b) => {
      b.classList.remove('active');
      b.setAttribute('aria-selected', 'false');
    });
    document.querySelectorAll('.tab-panel').forEach((p) => p.classList.remove('active'));
    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');
    const panel = document.getElementById('panel-' + btn.dataset.tab);
    panel?.classList.add('active');
  });
});

// ─── Valve Canvas Animation ──────────────────────────────────────
(function () {
  const canvas = document.getElementById('valve-canvas') as HTMLCanvasElement;
  const btn = document.getElementById('valve-toggle') as HTMLButtonElement;
  const label = document.getElementById('valve-state-label')!;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  let lit = false;
  let lightPulse = 0; // 0-1
  let plugPos = 0;    // 0 = away (open), 1 = at pore (closed)
  let animFrame = 0;

  function draw() {
    const W = canvas.offsetWidth;
    const H = canvas.offsetHeight;
    canvas.width = W;
    canvas.height = H;

    ctx.clearRect(0, 0, W, H);

    const cx = W / 2;
    const poreY = H / 2 + 10;
    const poreW = 60;
    const poreH = 24;

    // --- Cell wall (horizontal bar) ---
    ctx.fillStyle = '#1F2937';
    ctx.fillRect(0, poreY - poreH / 2 - 8, W, 8);
    ctx.fillRect(0, poreY + poreH / 2, W, 8);

    // Pore opening
    ctx.fillStyle = '#111827';
    ctx.fillRect(cx - poreW / 2, poreY - poreH / 2, poreW, poreH);

    // Pore rim (SPA1-ePDZ anchor)
    ctx.strokeStyle = '#2B7FFF';
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    ctx.rect(cx - poreW / 2, poreY - poreH / 2, poreW, poreH);
    ctx.stroke();
    ctx.fillStyle = '#2B7FFF';
    ctx.font = 'bold 8px Inter, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('SPA1-ePDZ anchor', cx, poreY + poreH / 2 + 18);

    // Flow arrows (left side = upper cytoplasm, right = lower)
    const flowAlpha = 1 - plugPos;
    if (flowAlpha > 0.05) {
      ctx.globalAlpha = flowAlpha;
      ctx.strokeStyle = '#00D4AA';
      ctx.lineWidth = 2;
      // Downward flow through pore
      for (let i = -1; i <= 1; i++) {
        const fx = cx + i * 16;
        const animate = ((Date.now() / 400 + i * 0.3) % 1);
        const ay = (poreY - poreH / 2 - 20) + animate * (poreH + 40);
        ctx.beginPath();
        ctx.moveTo(fx, ay - 8);
        ctx.lineTo(fx, ay + 8);
        ctx.moveTo(fx - 4, ay + 2);
        ctx.lineTo(fx, ay + 8);
        ctx.lineTo(fx + 4, ay + 2);
        ctx.stroke();
      }
      ctx.globalAlpha = 1;
    }

    // HEX1-LOV2 plug position
    const plugX = cx + (1 - plugPos) * (W / 2 - cx - 40);
    const plugY = poreY - 30 - plugPos * 30;
    const r = 18;

    // Glow when lit
    if (lightPulse > 0) {
      const glow = ctx.createRadialGradient(plugX, plugY, 2, plugX, plugY, 40);
      glow.addColorStop(0, `rgba(43,127,255,${lightPulse * 0.5})`);
      glow.addColorStop(1, 'rgba(43,127,255,0)');
      ctx.beginPath();
      ctx.arc(plugX, plugY, 40, 0, Math.PI * 2);
      ctx.fillStyle = glow;
      ctx.fill();
    }

    ctx.beginPath();
    ctx.arc(plugX, plugY, r, 0, Math.PI * 2);
    const plugGrad = ctx.createRadialGradient(plugX - 5, plugY - 5, 2, plugX, plugY, r);
    plugGrad.addColorStop(0, lit ? '#4B91FF' : '#00D4AA');
    plugGrad.addColorStop(1, lit ? '#1a50CC' : '#007A5E');
    ctx.fillStyle = plugGrad;
    ctx.fill();
    ctx.strokeStyle = lit ? '#2B7FFF' : '#00D4AA';
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Label on plug
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 7px Inter, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('HEX1', plugX, plugY - 2);
    ctx.fillText('LOV2', plugX, plugY + 8);

    // Light ray
    if (lightPulse > 0.1) {
      ctx.globalAlpha = lightPulse * 0.6;
      ctx.strokeStyle = '#2B7FFF';
      ctx.lineWidth = 2;
      ctx.setLineDash([5, 4]);
      ctx.beginPath();
      ctx.moveTo(20, 20);
      ctx.lineTo(plugX - r, plugY - r);
      ctx.stroke();
      ctx.setLineDash([]);

      // 450nm label
      ctx.globalAlpha = lightPulse;
      ctx.fillStyle = '#2B7FFF';
      ctx.font = '9px Inter, sans-serif';
      ctx.textAlign = 'left';
      ctx.fillText('450 nm', 22, 18);
      ctx.globalAlpha = 1;
    }

    // Status text (top right)
    ctx.fillStyle = flowAlpha > 0.5 ? '#00D4AA' : '#EF4444';
    ctx.font = 'bold 9px Inter, sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText(flowAlpha > 0.5 ? 'Flow OPEN' : 'Flow BLOCKED', W - 8, 18);
  }

  let animId: number;
  function animate() {
    // Smooth transitions
    const target = lit ? 1 : 0;
    plugPos += (target - plugPos) * 0.08;
    lightPulse += (target - lightPulse) * 0.1;
    draw();
    animId = requestAnimationFrame(animate);
  }
  animate();

  btn.addEventListener('click', () => {
    lit = !lit;
    if (lit) {
      label.textContent = 'LIT (450 nm) — Flow BLOCKED';
      label.style.background = 'rgba(239,68,68,0.15)';
      label.style.color = '#EF4444';
    } else {
      label.textContent = 'DARK — Flow OPEN';
      label.style.background = 'rgba(0,212,170,0.15)';
      label.style.color = '#00D4AA';
    }
  });

  // Auto-play when tab is visible
  const tabValve = document.querySelector('[data-tab="valve"]')!;
  tabValve.addEventListener('click', () => {
    let cycle = 0;
    const autoId = setInterval(() => {
      lit = !lit;
      label.textContent = lit ? 'LIT (450 nm) — Flow BLOCKED' : 'DARK — Flow OPEN';
      label.style.background = lit ? 'rgba(239,68,68,0.15)' : 'rgba(0,212,170,0.15)';
      label.style.color = lit ? '#EF4444' : '#00D4AA';
      cycle++;
      if (cycle >= 4) clearInterval(autoId);
    }, 2000);
  });
})();

// ─── H-Tree Chip Canvas Explorer ────────────────────────────────
(function () {
  const canvas = document.getElementById('chip-canvas') as HTMLCanvasElement;
  const resetBtn = document.getElementById('chip-reset')!;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  // H-tree coordinates (in a 10000×10000 logical space)
  const S = 10000; // SVG space size
  // Center
  const CX = S / 2, CY = S / 2;

  // H-tree: start horizontal, L0 half = 2500
  // Level 0: (2500,5000)-(7500,5000), L=5000
  // Level 1: vert at each end, L=5000/sqrt(2)≈3536, half=1768
  // Level 2: horiz at each end, half=1768/sqrt(2)≈1250
  // Level 3: vert at each end, half=1250/sqrt(2)≈884

  const HL0 = 2500;
  const HL1 = Math.round(HL0 / Math.sqrt(2)); // 1768
  const HL2 = Math.round(HL1 / Math.sqrt(2)); // 1250
  const HL3 = Math.round(HL2 / Math.sqrt(2)); // 884

  // All channel segments: [x1,y1,x2,y2,level]
  type Seg = [number, number, number, number, number];
  const segs: Seg[] = [];

  // Level 0 horizontal trunk
  segs.push([CX - HL0, CY, CX + HL0, CY, 0]);

  // Level 1 vertical at each L0 end
  const L1ends = [CX - HL0, CX + HL0];
  L1ends.forEach(lx => {
    segs.push([lx, CY - HL1, lx, CY + HL1, 1]);
  });

  // Level 2 horizontal at each L1 end
  const L2parents = L1ends.flatMap(lx => [{ x: lx, y: CY - HL1 }, { x: lx, y: CY + HL1 }]);
  L2parents.forEach(p => {
    segs.push([p.x - HL2, p.y, p.x + HL2, p.y, 2]);
  });

  // Level 3 vertical at each L2 end — these end at the 16 port locations
  const L3parents = L2parents.flatMap(p => [{ x: p.x - HL2, y: p.y }, { x: p.x + HL2, y: p.y }]);
  const portLocations: {x: number, y: number}[] = [];
  L3parents.forEach(p => {
    segs.push([p.x, p.y - HL3, p.x, p.y + HL3, 3]);
    portLocations.push({ x: p.x, y: p.y - HL3 });
    portLocations.push({ x: p.x, y: p.y + HL3 });
  });

  // Pan/zoom state
  let ox = 0, oy = 0, scale = 1;
  let dragging = false;
  let lastX = 0, lastY = 0;

  function toCanvas(sx: number, sy: number) {
    const W = canvas.offsetWidth, H = canvas.offsetHeight;
    const baseScale = Math.min(W, H) / S * 0.8;
    const s = baseScale * scale;
    return {
      x: W / 2 + (sx - CX) * s + ox,
      y: H / 2 + (sy - CY) * s + oy,
    };
  }

  function draw() {
    const W = canvas.offsetWidth, H = canvas.offsetHeight;
    const dpr = window.devicePixelRatio || 1;
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.scale(dpr, dpr);

    ctx.fillStyle = '#0B0F19';
    ctx.fillRect(0, 0, W, H);

    // Draw segments
    segs.forEach(([x1, y1, x2, y2, lv]) => {
      const p1 = toCanvas(x1, y1), p2 = toCanvas(x2, y2);
      ctx.beginPath();
      ctx.moveTo(p1.x, p1.y);
      ctx.lineTo(p2.x, p2.y);
      ctx.strokeStyle = lv <= 1 ? '#00D4AA' : '#2B7FFF';
      ctx.lineWidth = lv === 0 ? 3 : lv === 1 ? 2.5 : lv === 2 ? 2 : 1.5;
      ctx.stroke();
    });

    // Ports
    portLocations.forEach((p) => {
      const c = toCanvas(p.x, p.y);
      ctx.beginPath();
      ctx.arc(c.x, c.y, Math.max(3, 6 * scale), 0, Math.PI * 2);
      ctx.fillStyle = '#F5A623';
      ctx.fill();
      ctx.strokeStyle = '#0B0F19';
      ctx.lineWidth = 1;
      ctx.stroke();
    });

    // Central reservoir
    const center = toCanvas(CX, CY - 1000);
    ctx.beginPath();
    ctx.arc(center.x, center.y, Math.max(6, 12 * scale), 0, Math.PI * 2);
    const rg = ctx.createRadialGradient(center.x, center.y, 2, center.x, center.y, 14 * scale);
    rg.addColorStop(0, '#00D4AA');
    rg.addColorStop(1, 'rgba(0,212,170,0.3)');
    ctx.fillStyle = rg;
    ctx.fill();
    ctx.strokeStyle = '#00D4AA';
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Label
    ctx.fillStyle = '#8B95A5';
    ctx.font = '10px Inter, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('Chow reservoir', center.x, center.y - 16 * scale - 4);
  }

  canvas.addEventListener('mousedown', (e) => {
    dragging = true;
    lastX = e.clientX; lastY = e.clientY;
    canvas.style.cursor = 'grabbing';
  });
  window.addEventListener('mousemove', (e) => {
    if (!dragging) return;
    ox += e.clientX - lastX;
    oy += e.clientY - lastY;
    lastX = e.clientX; lastY = e.clientY;
    draw();
  });
  window.addEventListener('mouseup', () => {
    dragging = false;
    canvas.style.cursor = 'grab';
  });
  canvas.addEventListener('wheel', (e) => {
    e.preventDefault();
    const delta = e.deltaY > 0 ? 0.9 : 1.1;
    scale = Math.max(0.3, Math.min(8, scale * delta));
    draw();
  }, { passive: false });

  // Touch support
  let lastTouchDist = 0;
  canvas.addEventListener('touchstart', (e) => {
    if (e.touches.length === 1) {
      dragging = true;
      lastX = e.touches[0].clientX; lastY = e.touches[0].clientY;
    } else if (e.touches.length === 2) {
      lastTouchDist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
    }
  });
  canvas.addEventListener('touchmove', (e) => {
    e.preventDefault();
    if (e.touches.length === 1 && dragging) {
      ox += e.touches[0].clientX - lastX;
      oy += e.touches[0].clientY - lastY;
      lastX = e.touches[0].clientX; lastY = e.touches[0].clientY;
      draw();
    } else if (e.touches.length === 2) {
      const d = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
      scale *= d / lastTouchDist;
      scale = Math.max(0.3, Math.min(8, scale));
      lastTouchDist = d;
      draw();
    }
  }, { passive: false });
  canvas.addEventListener('touchend', () => { dragging = false; });

  resetBtn.addEventListener('click', () => {
    ox = 0; oy = 0; scale = 1;
    draw();
  });

  const obs = new IntersectionObserver((e) => {
    if (e[0].isIntersecting) { draw(); obs.disconnect(); }
  }, { threshold: 0.1 });
  obs.observe(canvas);
  window.addEventListener('resize', draw);
})();
</script>
